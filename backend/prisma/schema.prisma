generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  passwordHash         String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  isPremiumTrial       Boolean    @default(false)
  trialRequested       Boolean    @default(false)
  trialUsername        String?    @unique
  trialPassword        String?
  assignedIp           String?
  trialExpiry          DateTime?
  currentStreamSession String?
  lastDownloadAt       DateTime?
  downloadsToday       Int        @default(0)
  profiles             Profile[]
  providers            Provider[]
}

model Profile {
  id                String             @id @default(uuid())
  userId            String
  name              String
  avatar            String?
  profileType       ProfileType        @default(ADULT)
  pin               String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  continueWatching  ContinueWatching[]
  favorites         Favorite[]
  playlists         Playlist[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchHistory     SearchHistory[]
  userNotifications UserNotification[]
  sessions          UserSession[]
  watchHistory      WatchHistory[]
  watchLater        WatchLater[]
}

model UserSession {
  id           String   @id @default(uuid())
  profileId    String
  device       String
  location     String?
  ipAddress    String?
  sessionToken String   @unique
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Provider {
  id                String           @id @default(uuid())
  userId            String
  providerType      ProviderType
  providerName      String
  serverUrl         String?
  username          String?
  encryptedPassword String?
  playlistUrl       String?
  status            ProviderStatus   @default(ACTIVE)
  lastSyncAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  liveCategories    LiveCategory[]
  liveChannels      LiveChannel[]
  movies            Movie[]
  movieCategories   MovieCategory[]
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  series            Series[]
  seriesCategories  SeriesCategory[]
  streamProfiles    StreamProfile[]
}

model LiveCategory {
  id                 String        @id @default(uuid())
  providerId         String
  providerCategoryId String
  name               String
  createdAt          DateTime      @default(now())
  provider           Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  channels           LiveChannel[]

  @@unique([providerId, providerCategoryId])
}

model LiveChannel {
  id               String       @id @default(uuid())
  providerId       String
  liveCategoryId   String
  providerStreamId String
  name             String
  logo             String?
  streamUrl        String
  epgId            String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  epgChannel       EpgChannel?  @relation(fields: [epgId], references: [id])
  category         LiveCategory @relation(fields: [liveCategoryId], references: [id], onDelete: Cascade)
  provider         Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model MovieCategory {
  id                 String   @id @default(uuid())
  providerId         String
  providerCategoryId String
  name               String
  createdAt          DateTime @default(now())
  movies             Movie[]
  provider           Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerCategoryId])
}

model Movie {
  id               String        @id @default(uuid())
  providerId       String
  movieCategoryId  String
  providerStreamId String
  name             String
  poster           String?
  backdrop         String?
  description      String?
  director         String?
  actors           String?
  year             Int?
  rating           Float?
  duration         Int?
  streamUrl        String
  createdAt        DateTime      @default(now())
  category         MovieCategory @relation(fields: [movieCategoryId], references: [id], onDelete: Cascade)
  provider         Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerStreamId])
}

model SeriesCategory {
  id                 String   @id @default(uuid())
  providerId         String
  providerCategoryId String
  name               String
  createdAt          DateTime @default(now())
  series             Series[]
  provider           Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerCategoryId])
}

model Series {
  id               String         @id @default(uuid())
  providerId       String
  seriesCategoryId String
  providerSeriesId String
  name             String
  poster           String?
  backdrop         String?
  description      String?
  director         String?
  actors           String?
  year             Int?
  createdAt        DateTime       @default(now())
  seasons          Season[]
  provider         Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category         SeriesCategory @relation(fields: [seriesCategoryId], references: [id], onDelete: Cascade)

  @@unique([providerId, providerSeriesId])
}

model Season {
  id           String    @id @default(uuid())
  seriesId     String
  seasonNumber Int
  name         String?
  episodes     Episode[]
  series       Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([seriesId, seasonNumber])
}

model Episode {
  id                String  @id @default(uuid())
  seriesId          String
  seasonId          String
  providerEpisodeId String
  episodeNumber     Int
  title             String?
  description       String?
  streamUrl         String
  duration          Int?
  season            Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seriesId, providerEpisodeId])
}

model EpgChannel {
  id           String        @id @default(uuid())
  providerId   String
  epgId        String
  channelName  String
  programs     EpgProgram[]
  liveChannels LiveChannel[]

  @@unique([providerId, epgId])
}

model EpgProgram {
  id           String     @id @default(uuid())
  epgChannelId String
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  epgChannel   EpgChannel @relation(fields: [epgChannelId], references: [id], onDelete: Cascade)
}

model Notification {
  id                String             @id @default(uuid())
  title             String
  message           String
  type              String             @default("INFO")
  link              String?
  createdAt         DateTime           @default(now())
  userNotifications UserNotification[]
}

model UserNotification {
  id             String       @id @default(uuid())
  profileId      String
  notificationId String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, notificationId])
}

model Favorite {
  id          String      @id @default(uuid())
  profileId   String
  contentType ContentType
  contentId   String
  createdAt   DateTime    @default(now())
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model WatchLater {
  id          String      @id @default(uuid())
  profileId   String
  contentType ContentType
  contentId   String
  createdAt   DateTime    @default(now())
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model WatchHistory {
  id          String      @id @default(uuid())
  profileId   String
  contentType ContentType
  contentId   String
  watchedAt   DateTime    @default(now())
  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ContinueWatching {
  id              String      @id @default(uuid())
  profileId       String
  contentType     ContentType
  contentId       String
  positionSeconds Int
  durationSeconds Int?
  lastWatched     DateTime    @default(now())
  profile         Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId, contentType])
}

model Playlist {
  id          String         @id @default(uuid())
  profileId   String
  name        String
  description String?
  createdAt   DateTime       @default(now())
  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items       PlaylistItem[]
}

model PlaylistItem {
  id          String      @id @default(uuid())
  playlistId  String
  contentType ContentType
  contentId   String
  position    Int
  playlist    Playlist    @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id         String   @id @default(uuid())
  profileId  String
  query      String
  searchedAt DateTime @default(now())
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         AdminRole      @default(MODERATOR)
  createdAt    DateTime       @default(now())
  sessions     AdminSession[]
  auditLogs    AuditLog[]
}

model AdminSession {
  id           String    @id @default(uuid())
  adminId      String
  sessionToken String    @unique
  createdAt    DateTime  @default(now())
  admin        AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String     @id @default(uuid())
  actorId    String?
  action     String
  target     String
  createdAt  DateTime   @default(now())
  adminActor AdminUser? @relation(fields: [actorId], references: [id])
}

model StreamProfile {
  id                  String      @id @default(uuid())
  providerId          String
  contentType         ContentType
  contentId           String
  videoCodec          String?
  resolution          String?
  fps                 Float?
  bitrate             Int?
  audioCodec          String?
  audioChannels       Int?
  audioLanguage       String?
  subtitleFormats     String?
  browserSupported    Boolean     @default(true)
  transcodingRequired Boolean     @default(false)
  transcodeType       String?
  isBroken            Boolean     @default(false)
  lastCheckedAt       DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  provider            Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([contentType, contentId])
}

model TrialProvider {
  id                String       @id @default(uuid())
  providerName      String
  providerType      ProviderType @default(XTREAM)
  serverUrl         String?
  username          String?
  encryptedPassword String?
  playlistUrl       String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model PaymentRequest {
  id            String   @id @default(uuid())
  userEmail     String
  userName      String
  plan          String
  amount        Int
  upiRef        String?
  screenshotB64 String
  status        String   @default("PENDING")
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum ProfileType {
  ADULT
  CHILD
}

enum ProviderType {
  XTREAM
  M3U
  STALKER
  MAG
  MINISTRA
  CUSTOM
}

enum ProviderStatus {
  ACTIVE
  ERROR
  SYNCING
  OFFLINE
}

enum ContentType {
  MOVIE
  SERIES
  EPISODE
  CHANNEL
}

enum AdminRole {
  MODERATOR
  ADMIN
  SUPER_ADMIN
  OWNER
}
